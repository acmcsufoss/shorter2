{
  "name": "@shorter2/service",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "module": "src/index.ts",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy -e production",
    "dev": "wrangler dev --port 8788",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "format": "biome format --write ./src",
    "lint": "biome lint --write ./src",
    "check": "biome check ./src",
    "check:write": "biome check --write ./src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shorter2/types": "workspace:*",
    "chanfana": "^3.2.1",
    "hono": "^4.12.3",
    "qrcode-svg": "^1.1.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "22.13.0",
    "@types/qrcode-svg": "^1.1.5",
    "@types/service-worker-mock": "^2.0.4",
    "wrangler": "^4.69.0"
  }
}
